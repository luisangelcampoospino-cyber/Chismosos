<!DOCTYPE html>
<html>
<head>
<title>Chismoso</title>

<style>
body{
margin:0;
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
font-family:Arial;
color:white;
overflow:hidden;
}

/* GIF del pato de fondo */
.fondo{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
object-fit:cover;
z-index:-1;
opacity:0.4;
}

/* Borde de colores */
body{
border:12px solid;
border-image: linear-gradient(270deg, red, orange, yellow, lime, cyan, blue, purple, red) 1;
animation:mover 3s linear infinite;
}

@keyframes mover{
0%{border-image: linear-gradient(0deg, red, orange, yellow, lime, cyan, blue, purple, red) 1;}
50%{border-image: linear-gradient(180deg, red, orange, yellow, lime, cyan, blue, purple, red) 1;}
100%{border-image: linear-gradient(360deg, red, orange, yellow, lime, cyan, blue, purple, red) 1;}
}

h1{
font-size:70px;
text-shadow:0 0 10px white,0 0 20px cyan,0 0 30px purple;
margin:0;
}

p{
margin-top:20px;
font-size:20px;
}
</style>

</head>

<body>

<img class="fondo" src="https://media3.giphy.com/media/v1.Y2lkPTc5MGI3NjExbTZyaWt4b3JmNHhmbmxnc20yNmJnanFrM2I5MzRuNXc5aTR4NXRxaCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/PQHZH0iHMCmrNhRcE9/giphy.gif">

<h1>CHISMOSO</h1>
<p>By Luchoss</p>

</body>
</html>
